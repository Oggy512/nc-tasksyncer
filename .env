# Nextcloud CalDAV URL of the specific task list/calendar.
NC_CALDAV_URL=https://
NC_USERNAME=
NC_PASSWORD=

# Google Calendar target. Share this calendar with the service account email and grant "Make changes to events".
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json
GOOGLE_CALENDAR_ID=

# Runtime
TZ=Europe/Berlin
SYNC_INTERVAL_SECONDS=607
LOG_LEVEL=DEBUG
DRY_RUN=false

# Event creation policy
# Used only if the VTODO DUE/DTSTART value has no explicit time.
DEFAULT_EVENT_TIME=10:00 #Start Uhrzeit
EVENT_DURATION_MINUTES=30
REMINDER_MINUTES=15
IGNORE_UNDATED_TASKS=true

# Overdue handling: move_to_today or keep_due_date
# move_to_today preserves the original due time and moves only the date.
OVERDUE_MODE=move_to_today

# Completed/cancelled handling: delete_event or mark_done / mark_cancelled
# mark_* keeps the event visible and prefixes the status in the title.
COMPLETED_MODE=mark_done
CANCELLED_MODE=mark_cancelled

# Title rendering
# STATUS_TITLE_MODE: emoji [Play, Tickmark, ...], label, none
# PRIORITY_TITLE_MODE: emoji [Farbe], label [P1, P2,...], none
STATUS_TITLE_MODE=emoji
PRIORITY_TITLE_MODE=emoji
TASK_TITLE_PREFIX_OVERDUE=⚠
PRIORITY_HIGH_PREFIX=🔴
PRIORITY_MEDIUM_PREFIX=🟠
PRIORITY_LOW_PREFIX=🔵
PRIORITY_NONE_PREFIX=

# Recurring VTODO handling
# Recurring tasks are expanded into individual Google Calendar events.
RECURRENCE_EXPAND_DAYS=540
RECURRENCE_LOOKBACK_DAYS=30
RECURRENCE_INCLUDE_LATEST_OVERDUE=true
