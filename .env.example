# ==============================================================================
# Nextcloud Task to Google Calendar Sync - Configuration
# Version 0.2.0
# ==============================================================================

# Google service account JSON file mounted into the container.
GOOGLE_SERVICE_ACCOUNT_FILE=/app/secrets/google-service-account.json

# ----------------------------------------------------------------------------
# Shared task list -> shared Google calendar
# ----------------------------------------------------------------------------
# SHARED_* variables are preferred in version 0.2.0.
# For backward compatibility, NC_CALDAV_URL, NC_USERNAME, NC_PASSWORD and
# GOOGLE_CALENDAR_ID are still accepted for the shared target.
SHARED_ENABLED=true
SHARED_NAME=Gemeinsame Aufgaben
SHARED_NC_CALDAV_URL=https://cloud.example.com/remote.php/dav/calendars/shared-user/family-tasks/
SHARED_NC_USERNAME=shared-user
SHARED_NC_PASSWORD=<nextcloud-app-password>
SHARED_GOOGLE_CALENDAR_ID=<shared-calendar-id>@group.calendar.google.com

# ----------------------------------------------------------------------------
# Optional personal task list 1 -> personal Google calendar 1
# ----------------------------------------------------------------------------
PERSONAL1_ENABLED=false
PERSONAL1_NAME=Persönliche Aufgaben Markus
PERSONAL1_NC_CALDAV_URL=https://cloud.example.com/remote.php/dav/calendars/markus/personal-tasks/
PERSONAL1_NC_USERNAME=markus
PERSONAL1_NC_PASSWORD=<nextcloud-app-password>
# For a user's primary Google calendar, the calendar ID is normally the user's
# Google email address. The calendar must be shared with the service account.
PERSONAL1_GOOGLE_CALENDAR_ID=markus@example.com

# ----------------------------------------------------------------------------
# Optional personal task list 2 -> personal Google calendar 2
# ----------------------------------------------------------------------------
PERSONAL2_ENABLED=false
PERSONAL2_NAME=Persönliche Aufgaben Partnerin
PERSONAL2_NC_CALDAV_URL=https://cloud.example.com/remote.php/dav/calendars/partner/personal-tasks/
PERSONAL2_NC_USERNAME=partner
PERSONAL2_NC_PASSWORD=<nextcloud-app-password>
PERSONAL2_GOOGLE_CALENDAR_ID=partner@example.com

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------
TZ=Europe/Berlin
SYNC_INTERVAL_SECONDS=600
LOG_LEVEL=INFO
DRY_RUN=true

# ----------------------------------------------------------------------------
# Event creation policy
# ----------------------------------------------------------------------------
# Used only if VTODO DUE/DTSTART contains no explicit time.
DEFAULT_EVENT_TIME=08:00
EVENT_DURATION_MINUTES=15
REMINDER_MINUTES=0
IGNORE_UNDATED_TASKS=true

# Overdue handling: move_to_today or keep_due_date
# move_to_today changes only the event date and preserves the original due time.
OVERDUE_MODE=move_to_today

# Completed/cancelled handling
# COMPLETED_MODE: delete_event or mark_done
# CANCELLED_MODE: delete_event or mark_cancelled
COMPLETED_MODE=mark_done
CANCELLED_MODE=mark_cancelled

# ----------------------------------------------------------------------------
# Title rendering
# ----------------------------------------------------------------------------
# STATUS_TITLE_MODE: emoji, label, none
# PRIORITY_TITLE_MODE: emoji, label, none
STATUS_TITLE_MODE=emoji
PRIORITY_TITLE_MODE=emoji
TASK_TITLE_PREFIX_OVERDUE=⚠
PRIORITY_HIGH_PREFIX=🔴
PRIORITY_MEDIUM_PREFIX=🟠
PRIORITY_LOW_PREFIX=🔵
PRIORITY_NONE_PREFIX=

# ----------------------------------------------------------------------------
# Recurring VTODO handling
# ----------------------------------------------------------------------------
# Recurring tasks are expanded into individual Google Calendar events.
RECURRENCE_EXPAND_DAYS=180
RECURRENCE_LOOKBACK_DAYS=30
RECURRENCE_INCLUDE_LATEST_OVERDUE=true
